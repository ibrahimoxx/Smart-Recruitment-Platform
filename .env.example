# ===== DATABASE =====
DB_URL=jdbc:postgresql://localhost:5432/recruitment_db
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ===== JWT =====
# Minimum 32 characters — app will refuse to start if missing or too short
JWT_SECRET=your_minimum_32_char_secret_key_here_replace_this
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
JWT_ISSUER=smart-recruitment-platform

# ===== ANTHROPIC AI =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== MINIO =====
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_root_user
MINIO_SECRET_KEY=your_minio_root_password
MINIO_BUCKET_CV=recruitment-cv
MINIO_BUCKET_ASSETS=recruitment-assets
MINIO_SECURE=false

# ===== SPRING =====
SPRING_PROFILES_ACTIVE=dev
