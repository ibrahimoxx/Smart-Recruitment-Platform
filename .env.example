# Copy this file to .env and fill in all values before running the app
# .env is gitignored — never commit it

# ===== DATABASE =====
DB_URL=jdbc:postgresql://localhost:5432/recruitment_platform
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ===== JWT (minimum 32 characters) =====
JWT_SECRET=your_minimum_32_char_secret_key_here_replace_this
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# ===== MINIO =====
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_root_user
MINIO_SECRET_KEY=your_minio_root_password
MINIO_BUCKET_CV=recruitment-cv
MINIO_BUCKET_ASSETS=recruitment-assets

# ===== SPRING =====
SPRING_PROFILES_ACTIVE=dev

# ===== ANTHROPIC AI (re-enable for deployment — comment out Ollama section) =====
# ANTHROPIC_API_KEY=sk-ant-...

# ===== OLLAMA AI (local dev — no API key needed) =====
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:latest
